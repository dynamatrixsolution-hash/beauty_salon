datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Category {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  order    Int       @default(0)
  services Service[]
}

model Service {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  slug             String   @unique
  description      String
  duration         Int      // in minutes
  pricing          Float    // in NPR
  categoryId       String   @db.ObjectId
  category         Category @relation(fields: [categoryId], references: [id])
  isActive         Boolean  @default(true)
  featured         Boolean  @default(false)
  image            String
  beforeAfterImage String?  // Optional before/after image path
  benefits         String   // newline-separated benefits
  faqs             String   // JSON-serialized string of question/answer pairs
  tags             String[]
  order            Int      @default(0)
  formId           String?  @db.ObjectId // Relation to FormTemplate
}

model Package {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        String   // BRIDAL, FACIAL, MEMBERSHIP, SEASONAL
  price       Float
  description String
  isActive    Boolean  @default(true)
  services    String[] @db.ObjectId // Array of Service IDs
}

model Staff {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  role           String        @default("Stylist") // Stylist, Therapist, Receptionist, Manager
  specialization String?
  experience     String?
  certifications String?       // comma-separated
  socials        String?       // comma-separated keys/values
  phone          String?
  email          String?
  image          String?
  featured       Boolean       @default(false)
  appointments   Appointment[]
}

model FormTemplate {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  fields String // JSON string
}

model Customer {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  phone        String
  email        String?
  notes        String?
  appointments Appointment[]
}

model Appointment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  dateTime      DateTime
  status        String   @default("pending") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  serviceId     String   @db.ObjectId
  serviceTitle  String
  staffId       String?  @db.ObjectId
  staff         Staff?   @relation(fields: [staffId], references: [id])
  customerId    String   @db.ObjectId
  customer      Customer @relation(fields: [customerId], references: [id])
  formData      String?  // JSON string
  notes         String?
  createdAt     DateTime @default(now())
}

model Product {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  brand          String
  description    String
  ingredients    String
  instructions   String
  recommendation String
  category       String   // skincare, haircare, makeup, spa, tools
  image          String
  featured       Boolean  @default(false)
}

model Inquiry {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  customerName  String
  customerEmail String
  customerPhone String
  type          String   // service, product, bridal, collab, general
  itemId        String?  // ID of service or product inquired
  itemTitle     String?  // Title of service or product
  details       String
  status        String   @default("pending") // pending, resolved
  createdAt     DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  slug      String   @unique
  content   String   // markdown content
  excerpt   String
  category  String
  author    String
  image     String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  customerName String
  rating       Int
  serviceType  String
  text         String
  image        String?
  status       String   @default("pending") // pending, approved
  createdAt    DateTime @default(now())
}

model AIKnowledgeBase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  question    String
  answer      String
  category    String
  isPriority  Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Transformation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  category    String   // skin, hair, makeup
  desc        String
  beforeImg   String
  afterImg    String
  beforeLabel String   @default("Before")
  afterLabel  String   @default("After")
  createdAt   DateTime @default(now())
}